{
  "version": 2,
  "functions": {
    "api/index.py": {
      "excludeFiles": "{node_modules/**,dist/**,.venv/**,.git/**,.idea/**,.vercel/**,src/**,__pycache__/**,*.ipynb,*.pkl,package-lock.json}"
    }
  },
  "rewrites": [
    { "source": "/predict", "destination": "/api" },
    { "source": "/explain", "destination": "/api" },
    { "source": "/health", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
